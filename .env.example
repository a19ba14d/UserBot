# Telegram API 凭据 (从 https://my.telegram.org 申请)
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=userbot

# 飞书/Lark 自定义机器人推送; false = 关闭飞书/Lark bot 推送
FEISHU_ENABLED=true
# 飞书/Lark 自定义机器人 Webhook; FEISHU_ENABLED=true 时必填
FEISHU_WEBHOOK_URL=
# 飞书/Lark 签名密钥 (在机器人安全设置中启用签名时填; 不启用留空)
FEISHU_SECRET=

# 倒计时时长 (秒); 收到触发消息后多久未回复则发送提醒
REMINDER_SECONDS=300

# 是否启用私聊提醒 (true/false)
ENABLE_PRIVATE_CHAT=true

# 是否在飞书提醒中包含原始消息内容 (隐私敏感, 关闭后只发送摘要)
INCLUDE_MESSAGE_TEXT=true

# 可选: 仅监听以下 chat_id (逗号分隔, 空 = 全部)
WHITELIST_CHAT_IDS=
# 可选: 跳过以下 chat_id (逗号分隔, 空 = 不跳过)
BLACKLIST_CHAT_IDS=

# 私聊 bot 默认忽略; 只有以下 bot 可触发私聊提醒
# bot user_id 逗号分隔
WHITELIST_BOT_IDS=
# bot username 逗号分隔, 支持带或不带 @
WHITELIST_BOT_USERNAMES=

# 日志级别: INFO / DEBUG / WARNING / ERROR
LOG_LEVEL=INFO

# Bark iOS 推送 (https://bark.day.app); 留空 = 禁用 Bark, 仅飞书提醒
# device_key 在 Bark App 首页可以看到/复制
BARK_DEVICE_KEY=
# Bark 服务器, 默认官方; 自建可改为 https://your-bark.example.com
BARK_SERVER_URL=https://api.day.app
# critical 级别可绕过静音/勿扰 (需 iOS 设置允许"重要警告")
BARK_CRITICAL=true
# call=1 让铃声重复 30 秒, 像电话一样
BARK_CALL=true
# 自定义铃声名 (Bark App 内置铃声), 留空用默认
BARK_SOUND=

# 上班打卡确认助手: 只提醒 + 本人确认后点击, 不支持无人值守自动打卡
CHECKIN_ENABLED=false
CHECKIN_TIMEZONE=Asia/Shanghai
CHECKIN_RANDOM_START=11:00
CHECKIN_RANDOM_END=11:30
CHECKIN_CHAT_TITLE=墨链公司-常规打卡群
CHECKIN_BOT_USERNAME=Web3CheckInAndOutbot
CHECKIN_BUTTON_TEXT=上班打卡
# 动态查找按钮失败时才使用; 0 = 禁用 fallback
CHECKIN_FALLBACK_MESSAGE_ID=18742
# 必须保持 true; 确认方式是在目标群发送 CHECKIN_CONFIRM_COMMAND
CHECKIN_CONFIRM_REQUIRED=true
CHECKIN_CONFIRM_COMMAND=/confirm_checkin
CHECKIN_SUCCESS_KEYWORDS=打卡成功,上班打卡成功,成功
CHECKIN_RESULT_TIMEOUT_SECONDS=60
CHECKIN_STATE_FILE=sessions/checkin_state.json
CHECKIN_SEARCH_LIMIT=800
